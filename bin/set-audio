#!/bin/bash

### set-audio #####################################################################################
# adjust the given mixer state/value.
# Dependencies: wpctl, notify-send
###################################################################################################

source $(dirname $(readlink -e $0))/tool/helpers

show() {
    value=$(wpctl get-volume "$1" | grep -oP '\d\.\d+' | head -n 1)
    value=$(echo "$value * 100" | bc | cut -d'.' -f1)
    muted=$(wpctl get-volume "$1" | grep -oP '\[MUTED\]' | head -n1)
    msg="Volume: $value"
    [[ ! -z "$muted" ]] && msg="$msg (muted)"
    notify-send -r $N_SET_AUDIO "${msg}" "$(render-bar ${value} 39)"
}

if [ "$#" -lt 2 ]; then
    echo "Usage: $0 <element> <operation>"
    exit 1
fi

ELEMENT="$1"
OPERATION="$2"

toggle_mute() {
    wpctl set-mute "$ELEMENT" toggle 1>/dev/null
    show $ELEMENT
}

adjust_volume() {
    wpctl set-volume "$ELEMENT" "$1" 1>/dev/null
    show $ELEMENT
}

# Main logic
case "$OPERATION" in
    toggle)
        toggle_mute
        ;;
    *)
        # Pass through to wpctl for volume adjustments
        adjust_volume "$OPERATION"
        ;;
esac
signal-status $SIG_AUDIO
